# Ignora tudo na raiz
/*

# Permite arquivos específicos na raiz
!.gitignore
!.zshrc
!.bashrc

# Permite pastas específicas na raiz
!.config/
!imagens/
!scripts/
!.local/
!.fonts/

# Ignora tudo dentro de .config
.config/*

# Permite apenas o que importa dentro de .config
!.config/hypr/
!.config/qtile/
!.config/alacritty/
!.config/ghostty/
!.config/kitty/
!.config/wezterm/
!.config/doom/
!.config/lazyvim/
!.config/leovim/
!.config/neovide/
!.config/nvim/
!.config/polybar/
!.config/picom/
!.config/rofi/
!.config/yazi/
!.config/autostart/*.sh
!.config/bashmacs/*.el

# Ignora lixo
*Zone.Identifier*

# Permite fontes
!.local/share/
.local/share/*
!.local/share/fonts/
