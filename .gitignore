# Ignora tudo por padrão
/*

# Exceto o .config e arquivos específicos na raiz
!.config/
!.zshrc
!.gitignore

# Dentro do .config, ignora tudo...
.config/*

# ...exceto as pastas importantes
!.config/alacritty/
!.config/autostart/
!.config/doom/
!.config/emacs/
!.config/fish/
!.config/ghostty/
!.config/hypr/
!.config/i3/
!.config/kitty/
!.config/kvantum/
!.config/lazyvim/
!.config/neovide/
!.config/nvim/
!.config/picom/
!.config/polybar/
!.config/qtile/
!.config/rio/
!.config/rofi/
!.config/sway/
!.config/variety/
!.config/waybar/
!.config/wezterm/
!.config/yazi/
!.config/tabby/
!.config/fastfetch/

# Arquivos diretos dentro de .config
!.config/mimeapps.list

# Fontes
!.local/share/fonts/
!.fonts/

# Ignora arquivos de metadados do Windows
*Zone.Identifier*

