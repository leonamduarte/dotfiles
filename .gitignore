# ============================================================
# SEGURANÇA CRÍTICA - NUNCA rastrear dados sensíveis
# ============================================================

/*.md
!README.md
!home/.agents/skills/**/*.md

# Credenciais e chaves
*.pem
*.key
*_rsa
*_ed25519
*id_rsa*
*id_ed25519*
*.ppk

# Diretórios sensíveis
.ssh/
.gnupg/
.password-store/
.aws/
.kube/

# Gemini agent - credenciais e dados de runtime
home/.agents/gemini/google_accounts.json
home/.agents/gemini/oauth_creds.json
home/.agents/gemini/projects.json
home/.agents/gemini/settings.json
home/.agents/gemini/state.json
home/.agents/gemini/installation_id
home/.agents/gemini/trustedFolders.json
home/.agents/gemini/history/
home/.agents/gemini/tmp/
# Ignore entire gemini agent directory (contains sensitive runtime credentials)
home/.agents/gemini/

# Fish shell (contém dados sensíveis)
.config/fish/conf.d/secrets.fish
home/.config/fish/fish_variables
**/fish_variables

# ============================================================
# ignores do Stow
# ============================================================

# Ignora tudo exceto o pacote 'home' e arquivos de config do repositório
/*
!.gitignore
!home/
!justfile

# ============================================================
# Lixo e caches
# ============================================================

*~
*.pyc
*.pyo
__pycache__/
node_modules/
*.bak
*Zone.Identifier*
.DS_Store
Thumbs.db

# Neovim / Vim
*.swp
*.swo
undo/
.netrw*

# Doom Emacs / Emacs
.dir-locals.el
.elc
.projectile

# Ignore opencode generated and temporary files
home/.config/opencode/.codex*
home/.config/opencode/*.log
home/.config/opencode/node_modules/

# But track opencode commands (custom .md files)
!home/.config/opencode/commands/*.md

# Ignore local app caches and installed binaries
home/.local/
