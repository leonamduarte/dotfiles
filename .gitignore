# ============================================================
# .gitignore — dotfiles (stow)
# ============================================================

# ============================================================
# SEGURANÇA CRÍTICA
# ============================================================

# NUNCA rastreie dados sensíveis (mesmo que permitidos depois)
.ssh/
.gnupg/
.password-store/
*.pem
*.key
*_rsa
*_ed25519
*id_rsa*
*id_ed25519*
*.ppk
.aws/
.kube/
.config/fish/conf.d/secrets.fish
.config/fish/fish_variables

# Permite arquivos específicos na raiz
!.gitignore
!.zshrc
!.bashrc

# Permite pastas específicas na raiz
!dot_config/

# Permite dot_config
!dot_config/alacritty/
!dot_config/autostart/
!dot_config/doom/
!dot_config/fish/
!dot_config/ghostty/
!dot_config/kitty/
!dot_config/mimeapps.list
!dot_config/niri/
!dot_config/nvim/
!dot_config/opencode/
!dot_config/starship.toml
!dot_config/wezterm/
!dot_config/yazi/

# Permite pastas específicas na raiz
!.config/
!scripts/
!.local/

# Ignora tudo dentro de .config
.config/*

# Permite apenas o que importa dentro de .config
!.config/hypr/*.conf
!.config/hypr/dms/
!.config/hypr/
!.config/qtile/
!.config/alacritty/
!.config/ghostty/
!.config/kitty/
!.config/wezterm/
!.config/doom/
!.config/lazyvim/
!.config/leovim/
!.config/neovide/
!.config/nvim/
!.config/opencode/
!.config/polybar/
!.config/picom/
!.config/rio/
!.config/rofi/
!.config/yazi/
!.config/autostart/*.sh
!.config/bashmacs/*.el
.opencode/

# Ignora lixo
*Zone.Identifier*
node_modules/
__pycache__/
*.pyc
*.bak

# Neovim / Vim swap & undo
*.swp
*.swo
undo/
.netrwhist
shada/

# Doom Emacs / Emacs
.dir-locals.el
.elc
*~
\#*\#
.projectile

mimeapps.list
*.pyc
__pycache__/
*.pyo
*.pyd

# Permite fontes
!.local/share/
.local/share/*
!.local/share/fonts/

# Ignore opencode generated files
config/.config/opencode/.codex*
config/.config/opencode/*.log

# Ignore local agent instructions (not for git)
AGENTS.md

# ============================================================
# OTIMIZAÇÃO: Dados gerados e binários (não são configurações)
# ============================================================

# Emacs - dados gerados (straight instala isso post-clone)
.config/emacs/.local/
.config/emacs/straight/repos/
.config/emacs/straight/build-*/
.config/emacs-vanilla/elpaca/
.config/emacs-vanilla/elpa/
.config/emacs-vanilla/eln-cache/
.config/emacs-vanilla/auto-save-list/
.config/emacs-vanilla/transient/
.config/emacs-vanilla/.local/

# Binários nativos (tree-sitter compila localmente)
*.dll
*.so
*.dylib
*.exe

# Mídia de documentação (GIFs de demos, screenshots)
*.gif
*.png
*.jpg
*.jpeg
*.webp
*.mov

# Fontes grandes (baixar post-clone se necessário)
*.ttf
*.otf
*.woff
*.woff2

# ============================================================
# SHALLOW CLONES: Configuração para submódulos futuros
# ============================================================
# Para clonar com depth=1:
#   git submodule add --depth 1 <repo>
#   git clone --depth 1 --recurse-submodules ...