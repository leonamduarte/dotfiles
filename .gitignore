# ============================================================
# SEGURANÇA CRÍTICA - NUNCA rastrear dados sensíveis
# ============================================================

# Credenciais e chaves
*.pem
*.key
*_rsa
*_ed25519
*id_rsa*
*id_ed25519*
*.ppk

# Diretórios sensíveis
.ssh/
.gnupg/
.password-store/
.aws/
.kube/

# Fish shell (contém dados sensíveis)
.config/fish/conf.d/secrets.fish
.config/fish/fish_variables

# ============================================================
# ignores do Stow
# ============================================================

# Ignora tudo exceto o pacote 'home'
/*
!.gitignore
!home/

# ============================================================
# Lixo e caches
# ============================================================

*~
.*.swp
.*.swo
*.pyc
*.pyo
__pycache__/
node_modules/
*.bak
*Zone.Identifier*

# Neovim / Vim
*.swp
*.swo
undo/
.netrw*

# Doom Emacs / Emacs
.dir-locals.el
.elc
.projectile

# Ignore opencode generated files
home/.config/opencode/.codex*
home/.config/opencode/*.log
home/.config/opencode/node_modules/

# ============================================================
# Documentação do projeto (não rastrear)
