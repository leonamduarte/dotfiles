
# Ignora tudo na raiz
/*

# ============================================================
# SEGURANÇA CRÍTICA
# ============================================================

# NUNCA rastreie dados sensíveis (mesmo que permitidos depois)
.ssh/
.gnupg/
.password-store/
*.pem
*.key
*_rsa
*_ed25519
*id_rsa*
*id_ed25519*
*.ppk
.aws/
.kube/
.config/fish/conf.d/secrets.fish
.config/fish/fish_variables

# Permite arquivos específicos na raiz
!.gitignore
!.zshrc
!.bashrc

# Permite pastas específicas na raiz
!.config/
!scripts/
!.local/

# Ignora tudo dentro de .config
.config/*

# Permite apenas o que importa dentro de .config
!.config/hypr/*.conf
!.config/hypr/dms/
!.config/hypr/
!.config/qtile/
!.config/alacritty/
!.config/ghostty/
!.config/kitty/
!.config/wezterm/
!.config/doom/
!.config/lazyvim/
!.config/leovim/
!.config/neovide/
!.config/opencode/
!.config/nvim/
!.config/polybar/
!.config/picom/
!.config/rio/
!.config/rofi/
!.config/yazi/
!.config/autostart/*.sh
!.config/bashmacs/*.el

# Ignora lixo
*Zone.Identifier*

# Neovim / Vim swap & undo
*.swp
*.swo
undo/
.netrwhist
shada/

# Doom Emacs / Emacs
.dir-locals.el
.elc
*~
\#*\#
.projectile

# Permite fontes
!.local/share/
.local/share/*
!.local/share/fonts/

# ============================================================
# OTIMIZAÇÃO: Dados gerados e binários (não são configurações)
# ============================================================

# Emacs - dados gerados (straight instala isso post-clone)
.config/emacs/.local/
.config/emacs/straight/repos/
.config/emacs/straight/build-*/

# Binários nativos (tree-sitter compila localmente)
*.dll
*.so
*.dylib
*.exe

# Mídia de documentação (GIFs de demos, screenshots)
*.gif
*.png
*.jpg
*.jpeg
*.webp
*.mp4
*.mov

# Fontes grandes (baixar post-clone se necessário)
*.ttf
*.otf
*.woff
*.woff2

# ============================================================
# SHALLOW CLONES: Configuração para submódulos futuros
# ============================================================
# Para clonar com depth=1:
#   git submodule add --depth 1 <repo>
#   git clone --depth 1 --recurse-submodules ...
