{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "router",
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": ["npx", "-y", "@cyanheads/git-mcp-server"],
      "enabled": true
    }
  }
}
