{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": ["opencode-gemini-auth@latest"],
  "agent": {
    "architect": {
      "mode": "subagent",
      "description": "Arquitetura: mapeia o repo e atualiza blueprints.md.",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:./prompts/architect.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "write": "ask",
        "edit": "ask",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow",
          "find *": "allow"
        },
        "skill": {
          "10-repo_analysis": "allow",
          "10-repo-docs": "allow",
          "40-architecture-guard": "allow",
          "20-feature-implement": "deny",
          "40-audit-code": "deny",
          "50-apply-audit-fixes": "deny",
          "90-model_router": "allow",
          "20-code_debug": "allow",
          "surgical-debug": "deny"
        }
      },
      "temperature": 0.2,
      "steps": 4
    },

    "executor": {
      "mode": "subagent",
      "description": "Executor: implementa features e testes.",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow",
          "./gradlew *": "allow",
          "git push*": "deny",
          "go build*": "allow",
          "go run*": "allow",
          "go test*": "allow",
          "go mod *": "allow",
          "go fmt*": "allow",
          "go list*": "allow"
        },
        "skill": {
          "10-repo_analysis": "allow",
          "10-repo-docs": "allow",
          "40-architecture-guard": "allow",
          "20-feature-implement": "allow",
          "40-audit-code": "deny",
          "50-apply-audit-fixes": "allow",
          "90-model_router": "allow",
          "20-code_debug": "allow",
          "20-code-simplifier": "allow",
          "surgical-debug": "deny"
        }
      },
      "temperature": 0.2
    },

    "auditor": {
      "mode": "subagent",
      "description": "Auditoria: QA impiedoso, só leitura + relatório.",
      "model": "opencode-go/kimi-k2.5",
      "prompt": "{file:./prompts/auditor.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        },
        "skill": {
          "10-repo_analysis": "allow",
          "10-repo-docs": "deny",
          "40-architecture-guard": "allow",
          "20-feature-implement": "deny",
          "40-audit-code": "allow",
          "50-apply-audit-fixes": "deny",
          "surgical-debug": "deny"
        }
      },
      "temperature": 0.1,
      "steps": 4
    },

    "code-simplifier": {
      "mode": "subagent",
      "description": "Simplificador: refina código recém-modificado para clareza e manutenção sem alterar comportamento.",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/code-simplifier.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        },
        "skill": {
          "10-repo_analysis": "allow",
          "20-code-simplifier": "allow"
        }
      },
      "temperature": 0.1,
      "steps": 5
    }
  },

  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/home/paesmont"],
      "enabled": true
    }
  }
}
