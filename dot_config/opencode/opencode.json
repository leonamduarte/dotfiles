{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "github-copilot/gpt-5-mini",
  "small_model": "github-copilot/gpt-5-mini",
  "plugin": [],
  "default_agent": "build",
  "agent": {
    "build": {
      "permission": {
        "task": {
          "*": "deny",
          "auditor": "allow",
          "copilot-worker": "allow",
          "tester": "allow",
          "implementer": "allow"
        }
      }
    }
  },
  "permission": {
    "doom_loop": "ask",
    "external_directory": {
      "~/**": "ask"
    }
  }
}
