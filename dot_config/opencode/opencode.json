{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": ["opencode-gemini-auth@latest"],
  "default_agent": "router",
  "agent": {
    "router": {
      "mode": "primary",
      "description": "Router principal: classifica a tarefa e delega para o subagente certo.",
      "model": "opencode/minimax-m2.5-free",
      "prompt": "{file:./prompts/router.txt}",
      "color": "#7c3aed",
      "temperature": 0.1,
      "steps": 5,
      "permission": {
        "read": "deny",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "write": "deny",
        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "planner-gpt": "allow",
          "ui-glm": "allow",
          "executor": "allow",
          "copilot-worker": "allow",
          "auditor-gpt": "allow",
          "claude-surgeon": "ask"
        },
        "skill": {
          "90-model_router": "allow",
          "90-parallel": "allow",
          "10-repo_analysis": "allow",
          "20-feature-implement": "allow",
          "20-code_debug": "allow",
          "20-code-simplifier": "allow",
          "40-audit-code": "allow",
          "40-architecture-guard": "allow",
          "40-qa-review": "allow",
          "30-test-jest-unit": "allow",
          "30-test-jest-integration": "allow",
          "30-test-component": "allow",
          "30-test-e2e-maestro": "allow",
          "30-test-types": "allow",
          "30-test-lint": "allow"
        }
      }
    },
    "planner-gpt": {
      "mode": "subagent",
      "description": "Planner GPT: arquitetura, analise de repositorio, plano, riscos e trade-offs. Nao edita arquivos.",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/planner-gpt.txt}",
      "color": "#2563eb",
      "temperature": 0.2,
      "steps": 12,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "write": "deny",
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "task": { "*": "deny" },
        "skill": "deny"
      }
    },
    "ui-glm": {
      "mode": "subagent",
      "description": "UI GLM: exploracao de interface, UX de tela, alternativas visuais e estrutura inicial de componentes.",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:./prompts/ui-glm.txt}",
      "color": "#0891b2",
      "temperature": 0.3,
      "steps": 8,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "write": "deny",
        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny",
        "task": { "*": "deny" },
        "skill": "deny"
      }
    },
    "executor": {
      "mode": "subagent",
      "description": "Executor: implementa mudancas no projeto editando arquivos, criando arquivos, executando comandos e validando resultados. Use este agente sempre que o usuario pedir para aplicar, alterar, corrigir, rodar, testar ou executar algo no codebase.",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:./prompts/executor.txt}",
      "color": "#16a34a",
      "temperature": 0.2,
      "steps": 20,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "write": "allow",
        "edit": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow",
          "./gradlew *": "allow",
          "git push*": "deny",
          "go build*": "allow",
          "go run*": "allow",
          "go test*": "allow",
          "go mod *": "allow",
          "go fmt*": "allow",
          "go list*": "allow"
        },
        "webfetch": "allow",
        "task": { "*": "deny" },
        "skill": {
          "10-repo_analysis": "allow",
          "20-feature-implement": "allow",
          "20-code_debug": "allow",
          "20-code-simplifier": "allow",
          "30-test-component": "allow",
          "30-test-e2e-maestro": "allow",
          "30-test-jest-integration": "allow",
          "30-test-jest-unit": "allow",
          "30-test-lint": "allow",
          "30-test-types": "allow",
          "40-architecture-guard": "allow",
          "50-apply-audit-fixes": "allow",
          "90-model_router": "deny",
          "90-parallel": "deny"
        }
      }
    },
    "copilot-worker": {
      "mode": "subagent",
      "hidden": true,
      "description": "Copilot Worker: executor leve para tarefas simples, rapidas e de baixo risco.",
      "model": "openai/gpt-5-mini",
      "prompt": "{file:./prompts/executor.txt}",
      "color": "#65a30d",
      "temperature": 0.3,
      "steps": 8,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "write": "allow",
        "edit": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow"
        },
        "webfetch": "ask",
        "task": { "*": "deny" },
        "skill": {
          "20-code-simplifier": "allow",
          "30-test-lint": "allow",
          "30-test-types": "allow"
        }
      }
    },
    "auditor-gpt": {
      "mode": "subagent",
      "description": "Auditor GPT: revisao critica final, edge cases, riscos de manutencao e qualidade. Somente leitura.",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/auditor-gpt.txt}",
      "color": "#dc2626",
      "temperature": 0.1,
      "steps": 8,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "write": "deny",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        },
        "webfetch": "allow",
        "task": { "*": "deny" },
        "skill": {
          "40-audit-code": "allow",
          "40-architecture-guard": "allow",
          "40-qa-review": "allow",
          "90-parallel": "allow",
          "10-repo_analysis": "allow",
          "20-feature-implement": "deny",
          "20-code_debug": "deny",
          "20-code-simplifier": "deny",
          "50-apply-audit-fixes": "deny"
        }
      }
    },
    "claude-surgeon": {
      "mode": "subagent",
      "hidden": true,
      "description": "Claude Surgeon: resolve bugs de alta complexidade e problemas cirurgicos. Invocado apenas quando executor falha ou problema e critico.",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./prompts/claude-surgeon.txt}",
      "color": "#f59e0b",
      "temperature": 0.1,
      "steps": 6,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "write": "deny",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git diff*": "allow",
          "git log*": "allow"
        },
        "webfetch": "deny",
        "task": { "*": "deny" },
        "skill": "deny"
      }
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/home/paesmont"],
      "enabled": true
    }
  }
}
