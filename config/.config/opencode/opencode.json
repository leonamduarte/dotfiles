{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "ralph",
  "agent": {
    "build": {
      "description": "Default execution agent.",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/build.txt}",
      "steps": 120,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "auditor": "allow",
          "planner": "allow",
          "tester": "allow",
          "codex": "allow"
        }
      }
    },

    "router": {
      "description": "Task router.",
      "model": "openai/gpt-5.4-mini",
      "mode": "primary",
      "prompt": "Classify the task first and delegate to the best subagent. Never execute directly when a specialist fits.",
      "permission": {
        "task": {
          "*": "deny",
          "executor": "allow",
          "analista": "allow",
          "debug": "allow",
          "arquiteto": "allow",
          "codex": "allow"
        }
      }
    },

    "ralph": {
      "description": "Ralph orchestrator.",
      "model": "openai/gpt-5.4",
      "mode": "primary",
      "prompt": "{file:./prompts/ralph.txt}",
      "steps": 180,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "ralph-planner": "allow",
          "ralph-executor": "allow",
          "ralph-analyst": "allow",
          "ralph-debug": "allow",
          "ralph-tester": "allow",
          "ralph-reviewer": "allow",
          "ralph-codex": "allow",
          "ralph-arquiteto": "allow"
        }
      }
    },

    "executor": {
      "description": "Mechanical execution agent.",
      "model": "openai/gpt-5.4-mini",
      "mode": "subagent"
    },

    "analista": {
      "description": "Refactor agent.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "debug": {
      "description": "Debug agent.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "arquiteto": {
      "description": "Architecture agent.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "codex": {
      "description": "Critical code agent.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "tester": {
      "description": "Tester agent.",
      "model": "openai/gpt-5.4-mini",
      "mode": "subagent"
    },

    "ralph-planner": {
      "description": "Ralph planner.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "ralph-executor": {
      "description": "Ralph executor.",
      "model": "openai/gpt-5.4-mini",
      "mode": "subagent"
    },

    "ralph-analyst": {
      "description": "Ralph analyst.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "ralph-debug": {
      "description": "Ralph debug.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "ralph-tester": {
      "description": "Ralph tester.",
      "model": "openai/gpt-5.4-mini",
      "mode": "subagent"
    },

    "ralph-reviewer": {
      "description": "Ralph reviewer.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "ralph-codex": {
      "description": "Ralph codex.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "ralph-arquiteto": {
      "description": "Ralph architect.",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    }
  }
}
