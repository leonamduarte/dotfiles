{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": ["opencode-gemini-auth@latest"],
  "agent": {
    "architect": {
      "mode": "subagent",
      "description": "Arquitetura: mapeia o repo e atualiza blueprints.md.",
      "model": "opencode-go/kimi-k2.5",
      "prompt": "{file:./prompts/architect.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "permission": {
        "write": "ask",
        "edit": "ask",
        "bash": "deny"
      },
      "temperature": 0.2
    },

    "executor": {
      "mode": "subagent",
      "description": "Executor: implementa features e testes.",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow",
          "./gradlew *": "allow",
          "git push*": "deny",
          "go build*": "allow",
          "go run*": "allow",
          "go test*": "allow",
          "go mod *": "allow",
          "go fmt*": "allow",
          "go list*": "allow"
        }
      },
      "temperature": 0.2
    },

    "auditor": {
      "mode": "subagent",
      "description": "Auditoria: QA impiedoso, só leitura + relatório.",
      "model": "opencode-go/kimi-k2.5",
      "prompt": "{file:./prompts/auditor.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "bash": {
        "*": "ask",
        "git status*": "allow",
        "git diff*": "allow",
        "git log*": "allow",
        "grep *": "allow"
      },
      "temperature": 0.1
    },

    "code-simplifier": {
      "mode": "subagent",
      "description": "Simplificador: refina código recém-modificado para clareza e manutenção sem alterar comportamento.",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/code-simplifier.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "permission": {
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git diff*": "allow",
          "git log*": "allow"
        }
      },
      "temperature": 0.1,
      "steps": 5
    }
  }
}
