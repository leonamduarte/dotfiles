{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "opencode-go/minimax-m2.7",
  "small_model": "opencode-go/minimax-m2.5",
  "plugin": [],
  "default_agent": "build",
  "agent": {
    "build": {
      "description": "Agente padrao: coordena um fluxo minimo de execucao e QA.",
      "permission": {
        "task": {
          "*": "deny",
          "auditor": "allow",
          "copilot-worker": "allow",
          "planner": "allow",
          "tester": "allow",
          "implementer": "allow"
        }
      }
    },
    "executor": {
      "mode": "subagent",
      "description": "Implementa features e correcoes com validacao local.",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/executor.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": {
          "*": "ask",
          "rg *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow",
          "git push*": "deny"
        }
      },
      "temperature": 0.2,
      "steps": 6
    },
    "auditor": {
      "mode": "subagent",
      "description": "Revisao de qualidade focada em bugs, riscos, regressao e validacao.",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/auditor.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "rg *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        }
      },
      "temperature": 0.1,
      "steps": 4
    },
    "requirements-clarifier": {
      "mode": "subagent",
      "description": "Esclarece requisitos vagos e define criterios antes da implementacao.",
      "model": "opencode-go/minimax-m2.7",
      "prompt": "{file:./prompts/requirements-clarifier.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "temperature": 0.1,
      "steps": 4
    },
    "architect-designer": {
      "mode": "subagent",
      "description": "Analisa arquitetura, trade-offs e estrutura sem implementar codigo.",
      "model": "opencode-go/minimax-m2.7",
      "prompt": "{file:./prompts/architect.txt}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "rg *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        }
      },
      "temperature": 0.1,
      "steps": 4
    },
    "code-simplifier": {
      "mode": "subagent",
      "description": "Refina codigo para clareza sem mudar comportamento.",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/code-simplifier.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": {
          "*": "deny",
          "rg *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        }
      },
      "temperature": 0.1,
      "steps": 5
    }
  },
  "permission": {
    "doom_loop": "ask",
    "external_directory": {
      "~/**": "ask"
    }
  }
}
