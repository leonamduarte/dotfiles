{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "ralph",
  "agent": {
    "build": {
      "description": "Default execution agent for general coding, local validation and heavier implementations when appropriate.",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/build.txt}",
      "steps": 120,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "auditor": "allow",
          "planner": "allow",
          "tester": "allow",
          "codex": "allow"
        }
      }
    },

    "router": {
      "description": "Orquestrador principal para uso geral",
      "model": "openai/gpt-5.5-fast",
      "mode": "primary",
      "prompt": "Você é um orquestrador. Classifique a tarefa e delegue ao subagente correto. Nunca execute diretamente se um subagente fizer melhor.",
      "permission": {
        "task": {
          "*": "deny",
          "executor": "allow",
          "analista": "allow",
          "debug": "allow",
          "arquiteto": "allow",
          "codex": "allow"
        }
      }
    },

    "ralph": {
      "description": "Agente principal para Ralph Loop. Orquestra PRDs, JSONs complexos e builds longos.",
      "model": "openai/gpt-5.4",
      "mode": "primary",
      "prompt": "{file:./prompts/ralph.txt}",
      "steps": 180,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "ralph-planner": "allow",
          "ralph-executor": "allow",
          "ralph-analyst": "allow",
          "ralph-debug": "allow",
          "ralph-tester": "allow",
          "ralph-reviewer": "allow",
          "ralph-codex": "allow",
          "ralph-arquiteto": "allow"
        }
      }
    },

    "executor": {
      "description": "Tarefas mecânicas e boilerplate",
      "model": "openai/gpt-5.4-mini-fast",
      "mode": "subagent"
    },

    "analista": {
      "description": "Raciocínio médio e contexto longo",
      "model": "openai/gpt-5.5-fast",
      "mode": "subagent"
    },

    "debug": {
      "description": "Debug complexo e problemas travados",
      "model": "openai/gpt-5.5",
      "mode": "subagent"
    },

    "arquiteto": {
      "description": "Planejamento arquitetural e decisões críticas",
      "model": "openai/gpt-5.5",
      "mode": "subagent"
    },

    "codex": {
      "description": "Implementação crítica e revisão de código sensível",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "tester": {
      "description": "Executa testes, lint e validação",
      "model": "openai/gpt-5.4-mini",
      "mode": "subagent"
    },

    "ralph-planner": {
      "description": "Quebra PRDs em tarefas pequenas e ordenadas",
      "model": "openai/gpt-5.5-fast",
      "mode": "subagent"
    },

    "ralph-executor": {
      "description": "Implementação rápida e incremental",
      "model": "openai/gpt-5.4-fast",
      "mode": "subagent"
    },

    "ralph-analyst": {
      "description": "Analisa impacto entre módulos e dependências",
      "model": "openai/gpt-5.5-fast",
      "mode": "subagent"
    },

    "ralph-debug": {
      "description": "Debug pesado para loop travado",
      "model": "openai/gpt-5.5",
      "mode": "subagent"
    },

    "ralph-tester": {
      "description": "Validação automática e testes",
      "model": "openai/gpt-5.4-mini",
      "mode": "subagent"
    },

    "ralph-reviewer": {
      "description": "Revisão final de escopo, diff e regressões",
      "model": "openai/gpt-5.5-fast",
      "mode": "subagent"
    },

    "ralph-codex": {
      "description": "Cirurgia crítica em código, refactors arriscados e bugs difíceis",
      "model": "openai/gpt-5.4",
      "mode": "subagent"
    },

    "ralph-arquiteto": {
      "description": "Decisões arquiteturais raras e críticas",
      "model": "openai/gpt-5.5",
      "mode": "subagent"
    }
  }
}
