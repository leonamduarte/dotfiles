{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "agent": {
    "build": {
      "description": "Default execution agent for general coding, local validation and heavier implementations when appropriate.",
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:./prompts/build.txt}",
      "maxSteps": 120,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "auditor": "allow",
          "planner": "allow",
          "tester": "allow"
        }
      }
    }
  }
}
