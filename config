input * {
    xkb_layout br
    xkb_variant abnt2
}

output HDMI-A-1 resolution 1920x1080 position 0 0
output DP-1 mode 1440x900 position 1920 0

# Include system config first so we keep the system defaults (eg. $menu)
include /etc/sway/config

# User custom keybindings (placed after the system include so they take precedence)


# Terminal: Super+Enter -> wezterm (flatpak)
bindsym $mod+Return exec --no-startup-id /run/host/usr/bin/flatpak run org.wezfurlong.wezterm

# File manager: Super+Shift+f -> Thunar
bindsym $mod+Shift+f exec --no-startup-id /usr/bin/thunar

# Firefox: Super+Shift+b -> firefox
bindsym $mod+Shift+b exec --no-startup-id /usr/bin/firefox

# Edge (flatpak): Super+b -> Microsoft Edge
bindsym $mod+b exec --no-startup-id /run/host/usr/bin/flatpak run com.microsoft.Edge

# Neovim (toolbox dev): Super+Shift+n -> nvim inside toolbox
bindsym $mod+Shift+n exec --no-startup-id /usr/bin/toolbox run -c dev nvim

# Emacs (toolbox dev): Super+Shift+e -> emacs inside toolbox
bindsym $mod+Shift+e exec --no-startup-id /usr/bin/toolbox run -c dev emacs

# Spotify (flatpak): Super+Shift+m -> Spotify
bindsym $mod+Shift+m exec --no-startup-id /run/host/usr/bin/flatpak run com.spotify.Client

# Screenshot bindings added by assistant
# Full screen -> copy to clipboard
bindsym Print exec /var/home/leonamduarte/.local/bin/sway-screenshot full

# Select region -> copy to clipboard
bindsym Shift+Print exec /var/home/leonamduarte/.local/bin/sway-screenshot select

# Save screenshot to Pictures and copy
bindsym Ctrl+Print exec /var/home/leonamduarte/.local/bin/sway-screenshot save
