{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-runtime-fallback"],
  "default_agent": "ralph",
  "agent": {
    "build": {
      "description": "Default execution agent.",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./prompts/build.txt}",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "auditor": "allow",
          "planner": "allow",
          "tester": "allow",
          "codex": "allow"
        }
      }
    },
    "tutor": {
      "description": "Mentor técnico read-only que ensina sem implementar.",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./prompts/tutor.txt}",
      "mode": "primary",
      "color": "#f0c040",
      "steps": 120,
      "permission": {
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "deny",
        "bash": {
          "*": "allow"
        },
        "task": "deny",
        "skill": {
          "*": "deny",
          "tutor": "allow"
        }
      }
    },
    "leo": {
      "description": "Assistente pessoal faz-tudo — apenas o Leonam usa.",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "primary",
      "color": "#00d4aa",
      "steps": 120,
      "prompt": "Você é o assistente pessoal 'leo', exclusivo do Leonam.\n\nObjetivo:\n- Resolver qualquer tarefa que o Leonam pedir: codar, revisar, escrever, automatizar, pesquisar\n- Ser direto, prático e cuidadoso\n- Preferir mudanças pequenas e seguras\n- Explicar riscos e tradeoffs quando relevante\n\nRegras:\n- Não assuma requisitos — pergunte quando faltar contexto\n- Antes de alterar código, entenda o contexto primeiro\n- Com múltiplas opções corretas, prefira a mais simples\n- Mantenha compatibilidade e evite estragar o que funciona\n- Quando útil, esboce um plano curto antes de agir\n- Você tem permissão total: use bash, edite arquivos, crie branches, git commit, etc.",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow",
        "question": "allow",
        "todowrite": "allow"
      }
    },
    "router": {
      "description": "Task router.",
      "model": "openai/gpt-5.1-codex",
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-flash"
      ],
      "mode": "primary",
      "prompt": "Classifique a tarefa primeiro e delegue ao agente correto. Nunca execute diretamente quando um especialista for a melhor escolha.",
      "steps": 10,
      "permission": {
        "task": {
          "*": "deny",
          "executor": "allow",
          "analista": "allow",
          "debug": "allow",
          "arquiteto": "allow",
          "codex": "allow"
        }
      }
    },
    "ralph": {
      "description": "Ralph orchestrator.",
      "model": "openai/gpt-5.1-codex",
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-flash"
      ],
      "mode": "primary",
      "prompt": "{file:./prompts/ralph.txt}",
      "steps": 180,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "ralph-planner": "allow",
          "ralph-executor": "allow",
          "ralph-analyst": "allow",
          "ralph-debug": "allow",
          "ralph-tester": "allow",
          "ralph-reviewer": "allow",
          "ralph-codex": "allow",
          "ralph-arquiteto": "allow"
        }
      }
    },
    "executor": {
      "description": "Mechanical execution agent.",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent"
    },
    "analista": {
      "description": "Refactor agent.",
      "model": "opencode-go/kimi-k2.6",
      "mode": "subagent"
    },
    "debug": {
      "description": "Debug agent.",
      "model": "opencode-go/kimi-k2.6",
      "mode": "subagent"
    },
    "arquiteto": {
      "description": "Architecture agent.",
      "model": "opencode/big-pickle",
      "mode": "subagent"
    },
    "codex": {
      "description": "Critical code agent.",
      "model": "opencode-go/deepseek-v4-pro",
      "mode": "subagent"
    },
    "tester": {
      "description": "Tester agent.",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent"
    },
    "ralph-planner": {
      "description": "Ralph planner.",
      "model": "openai/gpt-5.1-codex",
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-flash"
      ],
      "mode": "subagent"
    },
    "ralph-executor": {
      "description": "Ralph executor.",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent"
    },
    "ralph-analyst": {
      "description": "Ralph analyst.",
      "model": "opencode-go/kimi-k2.6",
      "mode": "subagent"
    },
    "ralph-debug": {
      "description": "Ralph debug.",
      "model": "opencode-go/kimi-k2.6",
      "mode": "subagent"
    },
    "ralph-tester": {
      "description": "Ralph tester.",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent"
    },
    "ralph-reviewer": {
      "description": "Ralph reviewer.",
      "model": "openai/gpt-5.1-codex",
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-flash"
      ],
      "mode": "subagent"
    },
    "ralph-codex": {
      "description": "Ralph codex.",
      "model": "opencode-go/deepseek-v4-pro",
      "mode": "subagent"
    },
    "ralph-arquiteto": {
      "description": "Ralph architect.",
      "model": "opencode/big-pickle",
      "mode": "subagent"
    }
  }
}
