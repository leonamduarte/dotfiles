{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "agent": {
    "build": {
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "auditor": "allow",
          "planner": "allow",
          "tester": "allow",
          "codex": "allow",
          "executor": "allow",
          "analista": "allow",
          "debug": "allow",
          "arquiteto": "allow"
        }
      }
    },
    "executor": {
      "description": "Mechanical execution agent.",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent"
    },

    "analista": {
      "description": "Refactor agent.",
      "model": "openai/gpt-5.5",
      "mode": "subagent"
    },

    "debug": {
      "description": "Debug agent.",
      "model": "openai/gpt-5.5",
      "mode": "subagent"
    },

    "arquiteto": {
      "description": "Architecture agent.",
      "model": "openai/gpt-5.5",
      "mode": "subagent"
    },

    "codex": {
      "description": "Critical code agent.",
      "model": "openai/gpt-5.3-codex",
      "mode": "subagent"
    },

    "tester": {
      "description": "Tester agent.",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent"
    }
  }
}
