;; 1. Otimização de Startup
;; Aumenta o limite de coleta de lixo durante a inicialização para carregar mais rápido.
(setq gc-cons-threshold (* 50 1000 1000))

;; 2. Gerenciador de Pacotes (MELPA)
(require 'package)
(add-to-list 'package-archives '("melpa" . "https://melpa.org/packages/") t)
;; Comente a linha abaixo se você usar "elpa" padrão também, mas melpa é essencial.
;; (add-to-list 'package-archives '("gnu" . "https://elpa.gnu.org/packages/"))

(package-initialize)

;; Apenas para garantir que temos a lista de pacotes atualizada na primeira vez
(unless package-archive-contents
  (package-refresh-contents))

;; 3. Configuração do use-package
;; Nas versões novas do Emacs (29+), o use-package já vem instalado.
;; Esta linha garante que o Emacs baixe automaticamente qualquer pacote que
;; a gente declarar com 'use-package' se ele não estiver instalado.
(require 'use-package)
(setq use-package-always-ensure t)

;; 4. Limpeza de Diretórios (Imitando o Doom)
;; O Doom mantém sua pasta limpa. O Emacs puro joga arquivos de backup (~) e autosave (#)
;; por todo lado. O pacote 'no-littering' organiza isso em pastas específicas.
(use-package no-littering)

;; Mover arquivos de autosave e backup para fora do caminho visual
(setq auto-save-file-name-transforms
      `((".*" ,(no-littering-expand-var-file-name "auto-save/") t)))

;; --- 5. Evil Mode (Vim Emulation) ---

(use-package evil
  :init
  ;; Configurações que DEVEM rodar antes do plugin carregar
  (setq evil-want-integration t)  ;; Habilita integração básica
  (setq evil-want-keybinding nil) ;; Desliga atalhos padrão para o evil-collection agir
  (setq evil-want-C-u-scroll t)   ;; Permite usar C-u para rolar a tela (como no Vim)
  (setq evil-undo-system 'undo-redo) ;; Usa o sistema de undo nativo do Emacs 28+
  :config
  (evil-mode 1)) ;; Ativa o modo Evil globalmente

(use-package evil-collection
  :after evil
  :config
  (evil-collection-init)) ;; Ativa os bindings do Vim para o resto do Emacs (Magit, Dired, etc)

;; --- 6. Interface de Ajuda (O Menu que sobe) ---

(use-package which-key
  :init
  (which-key-mode)
  :config
  (setq which-key-idle-delay 0.3) ;; Tempo para o menu aparecer (Doom usa algo baixo assim)
  (setq which-key-popup-type 'side-window)
  (setq which-key-side-window-location 'bottom)
  (setq which-key-side-window-max-width 0.33))

;; --- 7. Mapeamento de Teclas (Leader Key) ---

(use-package general
  :config
  (general-evil-setup t)

  ;; Define o SPC como leader key nos estados 'normal' e 'visual' do Vim
  (general-create-definer leonam/leader-keys
    :states '(normal visual insert emacs)
    :keymaps 'override
    :prefix "SPC"       ;; Tecla líder no modo normal
    :global-prefix "C-SPC") ;; Tecla líder em outros modos (como insert)

  ;; Aqui começamos a reconstruir os menus do Doom
  (leonam/leader-keys
   "."     '(find-file :which-key "Find file")          ;; SPC . (Abrir arquivo)
   "SPC"   '(execute-extended-command :which-key "M-x") ;; SPC SPC (Rodar comando)
   
   ;; Grupo de Buffers (b)
   "b"     '(:ignore t :which-key "buffer")
   "bb"    '(switch-to-buffer :which-key "Switch buffer")
   "bk"    '(kill-current-buffer :which-key "Kill buffer")
   "bn"    '(next-buffer :which-key "Next buffer")
   "bp"    '(previous-buffer :which-key "Previous buffer")

   ;; Grupo de Files (f)
   "f"     '(:ignore t :which-key "file")
   "ff"    '(find-file :which-key "Find file")
   "fs"    '(save-buffer :which-key "Save file")
   
   ;; Grupo de Help (h)
   "h"     '(:ignore t :which-key "help")
   "hr"    '((lambda () (interactive) (load-file user-init-file)) :which-key "Reload init.el")))

;; --- 8. Sistema de Completar (Completion) ---

;; Vertico: Interface de lista vertical para completar comandos
(use-package vertico
  :init
  (vertico-mode)
  :config
  (setq vertico-cycle t)) ;; Permite rolar do último para o primeiro item

;; Persistência de Histórico (Lembra o que você digitou antes)
(use-package savehist
  :init
  (savehist-mode))

;; Marginalia: Anotações ricas ao lado dos itens (ex: descrição do comando M-x)
(use-package marginalia
  :after vertico
  :init
  (marginalia-mode))

;; Orderless: Busca inteligente (fuzzy search)
;; Exemplo: digitar "spc file" encontra "describe-function" se tiver as letras
(use-package orderless
  :custom
  (completion-styles '(orderless basic))
  (completion-category-overrides '((file (styles basic partial-completion)))))

;; --- 9. Aparência Visual (UI) ---

;; Fontes e Ícones
;; Instala a biblioteca de ícones necessária para o modeline e dired
(use-package nerd-icons)

;; Configuração de Fonte (Baseado no seu Arch Linux/VictorMono)
;; Se os ícones não aparecerem, certifique-se que a fonte está instalada no sistema.
(set-face-attribute 'default nil :family "VictorMono Nerd Font" :height 140)

;; Tema Doom One
(use-package doom-themes
  :config
  ;; Configurações globais do tema
  (setq doom-themes-enable-bold t    ; Habilita negrito
        doom-themes-enable-italic t) ; Habilita itálico
  (load-theme 'doom-one t)           ; Carrega o tema 'doom-one'

  ;; Melhora a visualização do Org-mode dentro do tema
  (doom-themes-org-config))

;; Modeline (A barra inferior do Doom)
(use-package doom-modeline
  :init (doom-modeline-mode 1)
  :config
  (setq doom-modeline-height 35)      ; Altura da barra (ajuste se ficar grande/pequena)
  (setq doom-modeline-family "VictorMono Nerd Font")) ; Garante que a barra use a fonte correta

;; Melhorias Visuais Gerais
(menu-bar-mode -1)           ; Remove a barra de menu do topo (File, Edit...)
(tool-bar-mode -1)           ; Remove a barra de ferramentas com ícones antigos
(scroll-bar-mode -1)         ; Remove a barra de rolagem lateral
(global-display-line-numbers-mode 1) ; Mostra numeração de linha
(setq display-line-numbers-type 'relative) ; Numeração relativa (estilo Vim/Doom)

;; --- 10. Git (Magit) ---

(use-package magit
  :commands (magit-status)
  :custom
  (magit-display-buffer-function #'magit-display-buffer-same-window-except-diff-v1))

;; Integração do "Todo" (highlight de TODO/FIXME no código)
(use-package hl-todo
  :hook ((prog-mode . hl-todo-mode)
         (org-mode . hl-todo-mode))
  :config
  (setq hl-todo-keyword-faces
        '(("TODO"   . "#dc322f")
          ("FIXME"  . "#dc322f")
          ("DEBUG"  . "#b58900")
          ("GOTCHA" . "#ff4500")
          ("STUB"   . "#1e90ff"))))

;; Atualizando os atalhos do General para incluir o Git
(leonam/leader-keys
 "g"   '(:ignore t :which-key "git")
 "gg"  '(magit-status :which-key "Magit status")
 "gB"  '(magit-blame-addition :which-key "Magit blame")
 "gc"  '(magit-clone :which-key "Clone repo")
 "gi"  '(magit-init :which-key "Init repo"))

;; --- 11. Org Mode (Produtividade e Anotações) ---

(use-package org
  :hook (org-mode . org-indent-mode) ;; Indentação visual automática (limpa a visão)
  :config
  (setq org-directory "~/org/"       ;; Sua pasta de notas
        org-default-notes-file (expand-file-name "inbox.org" org-directory)
        org-ellipsis " ▼ "           ;; Ícone bonito quando um tópico está fechado
        org-log-done 'time           ;; Grava a hora que você terminou a tarefa
        org-hide-emphasis-markers t) ;; Esconde a sintaxe *negrito* e /itálico/ deixando só o efeito

  ;; Recuperando seus status personalizados do Doom
  (setq org-todo-keywords
        '((sequence "TODO(t)" "IN-PROGRESS(i)" "WAIT(w)" "PROJ(p)" "|" "DONE(d)" "CANCELLED(c)")))
  
  ;; Cores para os status (opcional, ajuda a bater o olho rápido)
  (setq org-todo-keyword-faces
        '(("IN-PROGRESS" . "orange") ("WAIT" . "gray") ("PROJ" . "purple"))))

;; Org Modern: Transforma o Org Mode em algo "app-like"
;; Substitui asteriscos por ícones, melhora o espaçamento de tabelas e datas.
(use-package org-modern
  :hook (org-mode . org-modern-mode)
  :config
  (setq org-modern-star '("◉" "○" "◈" "◇" "✳" "◎") ;; Símbolos para os níveis de títulos
        org-modern-block-name nil    ;; Mantém nomes de blocos (SRC, QUOTE) simples
        org-modern-keyword nil))     ;; Mantém keywords (#+TITLE) simples

;; Org Auto Tangle: Essencial para sua filosofia de "Literate Config"
;; Toda vez que você salvar um arquivo .org com #+auto_tangle: t, ele gera o código.
(use-package org-auto-tangle
  :hook (org-mode . org-auto-tangle-mode))

;; Atalhos do Org (Estilo Doom)
(leonam/leader-keys
 "o"   '(:ignore t :which-key "org")
 "oa"  '(org-agenda :which-key "Agenda")
 "oc"  '(org-capture :which-key "Capture task")
 "oe"  '(org-export-dispatch :which-key "Export file")
 "ol"  '(org-store-link :which-key "Store link")
 "ot"  '(org-todo :which-key "Change TODO state"))

;; --- 12. Syntax Highlighting Moderno (Treesitter) ---
;; Usa a nova engine do Emacs 29+ para colorir código de forma rápida e precisa
(use-package treesit-auto
  :config
  (setq treesit-auto-install 'prompt) ;; Pergunta se quer instalar a gramática ao abrir um arquivo novo
  (global-treesit-auto-mode))

;; --- 13. Autocomplete Visual (Corfu) ---
;; A janelinha que mostra as sugestões enquanto você digita
(use-package corfu
  :init
  (global-corfu-mode)
  :config
  (setq corfu-auto t              ;; Abre automaticamente sem apertar nada
        corfu-auto-delay 0.1      ;; Delay minúsculo para não travar
        corfu-auto-prefix 2       ;; Começa a sugerir após 2 letras
        corfu-cycle t)            ;; Permite rodar a lista (chegou no fim, volta pro topo)
  
  ;; Extensão para mostrar ícones no menu de autocomplete
  (use-package nerd-icons-corfu
    :config
    (add-to-list 'corfu-margin-formatters #'nerd-icons-corfu-formatter)))

;; --- 14. O Cérebro da IDE (LSP Mode) ---
(use-package lsp-mode
  :init
  ;; Otimizações de performance recomendadas pelo lsp-mode
  (setq lsp-keymap-prefix "C-c l"
        lsp-idle-delay 0.500
        lsp-log-io nil) ;; Desligue logs para performance, ligue para debug
  :hook (;; Ativa o LSP automaticamente para estas linguagens
         (js-ts-mode . lsp)
         (typescript-ts-mode . lsp)
         (java-mode . lsp)
         (go-mode . lsp)
         (python-mode . lsp)
         ;; Integração com o which-key
         (lsp-mode . lsp-enable-which-key-integration))
  :commands lsp)

;; Interface Visual do LSP (Popups de documentação, sidebar, etc)
(use-package lsp-ui
  :commands lsp-ui-mode
  :config
  (setq lsp-ui-doc-enable t           ;; Mostra documentação ao passar o mouse/cursor
        lsp-ui-doc-position 'at-point ;; Mostra logo acima do cursor
        lsp-ui-sideline-show-diagnostics t ;; Mostra erros na lateral direita
        lsp-ui-sideline-show-code-actions t))

;; Suporte Específico para Java (Spring Boot etc)
(use-package lsp-java
  :after lsp)

;; --- 15. Formatação Automática (Prettier/Black/Gofmt) ---
(use-package apheleia
  :config
  (apheleia-global-mode +1)) ;; Salve o arquivo e ele formata sozinho!

;; --- 16. Atalhos de Código (Imitando o Doom "SPC c") ---
(leonam/leader-keys
 "c"   '(:ignore t :which-key "code")
 "ca"  '(lsp-execute-code-action :which-key "Code action") ;; O famoso "Quick Fix"
 "cd"  '(lsp-find-definition :which-key "Jump to definition")
 "cr"  '(lsp-rename :which-key "Rename variable")
 "cf"  '(apheleia-format-buffer :which-key "Format buffer")
 "cx"  '(lsp-java-organize-imports :which-key "Organize imports (Java)"))

(provide 'init)
;;; init.el ends here
(custom-set-variables
 ;; custom-set-variables was added by Custom.
 ;; If you edit it by hand, you could mess it up, so be careful.
 ;; Your init file should contain only one such instance.
 ;; If there is more than one, they won't work right.
 '(package-selected-packages
   '(corfu doom-modeline doom-themes evil-collection general hl-todo
	   lsp-java lsp-mode lsp-ui magit marginalia nerd-icons-corfu
	   no-littering orderless org-auto-tangle org-modern
	   treesit-auto vertico)))
(custom-set-faces
 ;; custom-set-faces was added by Custom.
 ;; If you edit it by hand, you could mess it up, so be careful.
 ;; Your init file should contain only one such instance.
 ;; If there is more than one, they won't work right.
 )
